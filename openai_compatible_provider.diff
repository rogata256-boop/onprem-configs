< from __future__ import annotations
< 
< import os
< import uuid
< from typing import Any, Dict, Optional
< 
< from langchain_ollama import ChatOllama
< from ollama import AsyncClient, Client
< 
< 
< class ChatOpenAICompatible(ChatOllama):
<     """
<     OpenAI-compatible chat model with custom header support.
<     
<     This class extends ChatOllama to add support for custom request headers,
<     particularly for request ID tracking. It works with any OpenAI-compatible
<     API including Ollama and Groq.
<     
<     Attributes:
<         request_id_header: Name of the header to use for request ID.
<                           Defaults to value from CUSTOM_LLM_REQUEST_ID_HEADER
<                           environment variable or "X-Request-ID".
<     
<     API Compatibility Notes:
<         - Groq API is fully OpenAI-compatible (https://console.groq.com/docs/openai)
<         - Ollama supports OpenAI-compatible endpoints
<         - Both support the same chat completions format and parameters
<     
<     Example:
<         >>> # In a LangGraph node, pass request_id from state
<         >>> def generate_query_node(state: OverallState, config: RunnableConfig):
<         ...     configurable = Configuration.from_runnable_config(config)
<         ...     # Pass request_id from state to track through execution
<         ...     llm = configurable.get_query_generator_model(
<         ...         temperature=0.0,
<         ...         request_id=state.get("request_id")
<         ...     )
<         ...     response = llm.invoke("What is the capital of France?")
<         ...     return {"response": response}
<     """
<     
<     request_id_header: str = "X-Request-ID"
<     request_id: Optional[str] = None
<     
<     def __init__(
<         self,
<         model: str = "gpt-oss:120b",
<         request_id: Optional[str] = None,
<         request_id_header: Optional[str] = None,
<         **kwargs: Any
<     ):
<         """
<         Initialize the OpenAI-compatible chat model.
<         
<         Args:
<             model: Model name to use (e.g., "gpt-oss:120b")
<             request_id: Optional request ID to use. If None, a UUID will be generated.
<                        This should typically come from your LangGraph state for
<                        consistent tracking across the graph execution.
<             request_id_header: Custom header name for request ID. 
<                              If None, uses CUSTOM_LLM_REQUEST_ID_HEADER env var
<                              or defaults to "X-Request-ID"
<             **kwargs: Additional arguments passed to ChatOllama
<         """
<         # Initialize the parent ChatOllama class first (required for Pydantic models)
<         super().__init__(model=model, **kwargs)
<         
<         # Set the request ID after parent initialization (from parameter or generate new one)
<         self.request_id = request_id or str(uuid.uuid4())
<         
<         # Set the request ID header from parameter, env var, or default
<         if request_id_header:
<             self.request_id_header = request_id_header
<         else:
<             self.request_id_header = os.environ.get(
<                 "CUSTOM_LLM_REQUEST_ID_HEADER", "X-Request-ID"
<             )
<     
<     def _get_request_headers(self) -> Dict[str, str]:
<         """
<         Generate headers for the request, including the custom request ID.
<         
<         Returns:
<             Dictionary of headers to include in the request
<         """
<         headers = {}
<         
<         # Use the request ID from initialization (from state or generated)
<         headers[self.request_id_header] = self.request_id
<         
<         return headers
<     
<     def _create_client(self) -> Client:
<         """
<         Create the Ollama client with custom headers.
<         
<         Returns:
<             Configured Ollama Client instance
<         """
<         # Get custom headers
<         custom_headers = self._get_request_headers()
<         
<         # Create client with custom headers
<         client_kwargs = {
<             "host": self.base_url,
<             "headers": custom_headers
<         }
<         
<         # Add timeout if configured
<         if hasattr(self, "timeout") and self.timeout:
<             client_kwargs["timeout"] = self.timeout
<         
<         return Client(**client_kwargs)
<     
<     def _create_async_client(self) -> AsyncClient:
<         """
<         Create the async Ollama client with custom headers.
<         
<         Returns:
<             Configured AsyncClient instance
<         """
<         # Get custom headers
<         custom_headers = self._get_request_headers()
<         
<         # Create async client with custom headers
<         client_kwargs = {
<             "host": self.base_url,
<             "headers": custom_headers
<         }
<         
<         # Add timeout if configured
<         if hasattr(self, "timeout") and self.timeout:
<             client_kwargs["timeout"] = self.timeout
<         
<         return AsyncClient(**client_kwargs)
<     
<     @property
<     def _llm_type(self) -> str:
<         """Return identifier for this LLM type."""
<         return "openai_compatible"
<     
<     @classmethod
<     def is_lc_serializable(cls) -> bool:
<         """Return whether this model can be serialized by Langchain."""
<         return True
<     
<     @classmethod
<     def get_lc_namespace(cls) -> list[str]:
<         """Get the namespace of the langchain object."""
<         return ["langchain", "chat_models", "openai_compatible"]
